{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tenacious-Bench Task Schema v0.3",
  "type": "object",
  "required": [
    "task_id",
    "split",
    "source_mode",
    "difficulty",
    "task_type",
    "failure_mode_tags",
    "input",
    "expected_behavior",
    "rubric",
    "metadata"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "split": {
      "type": "string",
      "enum": ["unsplit", "train", "dev", "held_out"]
    },
    "source_mode": {
      "type": "string",
      "enum": ["trace_derived", "programmatic", "multi_llm_synthesis", "adversarial"]
    },
    "difficulty": {
      "type": "string",
      "enum": ["easy", "medium", "hard"]
    },
    "task_type": {
      "type": "string",
      "enum": ["generate_outreach", "reply_to_objection", "rewrite_outreach", "abstain_decision"]
    },
    "failure_mode_tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["T-01", "T-02", "T-03", "T-04", "T-05", "T-06", "T-07", "T-08", "T-09"]
      }
    },
    "input": {
      "type": "object",
      "required": [
        "company_name",
        "hiring_signal",
        "evidence",
        "segment_confidence",
        "ai_maturity"
      ],
      "properties": {
        "company_name": { "type": "string" },
        "company_context": { "type": "string" },
        "hiring_signal": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "segment_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "ai_maturity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        }
      },
      "additionalProperties": true
    },
    "expected_behavior": {
      "type": "object",
      "required": [
        "action",
        "must_include",
        "must_avoid",
        "cta_required",
        "expected_output"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["send", "exploratory_send", "abstain", "review"]
        },
        "must_include": {
          "type": "array",
          "items": { "type": "string" }
        },
        "must_avoid": {
          "type": "array",
          "items": { "type": "string" }
        },
        "cta_required": { "type": "boolean" },
        "decision_rationale": { "type": "string" },
        "observed_action": {
          "type": "string",
          "enum": ["send", "exploratory_send", "abstain"]
        },
        "expected_output": {
          "type": "object",
          "required": ["email_subject", "email_body"],
          "properties": {
            "email_subject": { "type": "string" },
            "email_body": { "type": "string" }
          },
          "additionalProperties": false
        },
        "observed_output": {
          "type": "object",
          "required": ["email_subject", "email_body"],
          "properties": {
            "email_subject": { "type": "string" },
            "email_body": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "rubric": {
      "type": "object",
      "required": [
        "signal_grounding",
        "hallucination_control",
        "tone_style",
        "cta",
        "decision_correctness"
      ],
      "properties": {
        "signal_grounding": { "type": "number", "minimum": 0, "maximum": 1 },
        "hallucination_control": { "type": "number", "minimum": 0, "maximum": 1 },
        "tone_style": { "type": "number", "minimum": 0, "maximum": 1 },
        "cta": { "type": "number", "minimum": 0, "maximum": 1 },
        "decision_correctness": { "type": "number", "minimum": 0, "maximum": 1 },
        "segment_fit": { "type": "number", "minimum": 0, "maximum": 1 },
        "banned_phrase_control": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "required": ["version", "source_notes"],
      "properties": {
        "version": { "type": "string" },
        "source_notes": { "type": "string" },
        "family_id": { "type": "string" },
        "template_family_id": { "type": "string" },
        "trace_cluster_id": { "type": "string" },
        "original_trace_id": { "type": "string" },
        "conversion_confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
